  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-bug-reproduction",
  "homepage": "https://cortexprism.io/marketplace/plugins/bug-reproduction",
